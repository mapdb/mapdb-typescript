{
  "name": "@mapdb/typescript",
  "version": "0.1.0",
  "description": "High-performance primitive collections and lazy stream pipelines for TypeScript",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "npx vitest run",
    "typecheck": "tsc --noEmit",
    "format": "npx prettier --write src/"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "keywords": [
    "collections",
    "hashmap",
    "arraylist",
    "stream",
    "eclipse-collections",
    "primitive"
  ],
  "license": "EPL-1.0"
}
